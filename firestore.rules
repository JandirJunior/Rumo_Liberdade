rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getKingdomMember(kingdomId) {
      return get(/databases/$(database)/documents/kingdom_members/$(request.auth.uid + "_" + string(kingdomId)));
    }

    function isKingdomMember(kingdomId) {
      return isAuthenticated() && kingdomId != null && string(kingdomId) != "" && exists(/databases/$(database)/documents/kingdom_members/$(request.auth.uid + "_" + string(kingdomId)));
    }

    function getKingdomRole(kingdomId) {
      return getKingdomMember(kingdomId).data.role;
    }

    function hasKingdomPermission(kingdomId, roles) {
      return isKingdomMember(kingdomId) && getKingdomRole(kingdomId) in roles;
    }

    function isAdmin(kingdomId) {
      return hasKingdomPermission(kingdomId, ['admin']);
    }

    function isMember(kingdomId) {
      return hasKingdomPermission(kingdomId, ['admin', 'member']);
    }

    function isViewer(kingdomId) {
      return hasKingdomPermission(kingdomId, ['admin', 'member', 'viewer']);
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'jandirgabrieli@gmail.com';
    }

    function canDelete(data) {
      return isAuthenticated() && (
        ('created_by' in data && data.created_by == request.auth.uid) ||
        ('user_id' in data && data.user_id == request.auth.uid) ||
        ('userId' in data && data.userId == request.auth.uid) ||
        (!('kingdom_id' in data)) ||
        (data.kingdom_id == null) ||
        (data.kingdom_id == "") ||
        ('kingdom_id' in data && isMember(data.kingdom_id)) ||
        isSuperAdmin()
      );
    }

    // ===============================================================
    // Validator Helpers
    // ===============================================================

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidNumber(field, min) {
      return request.resource.data[field] is number && 
             request.resource.data[field] >= min;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Connection Test
    match /_connection_test/{docId} {
      allow read: if true;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated(); // Permite buscar usuários para convites
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // Kingdoms
    match /kingdoms/{kingdomId} {
      allow read: if isAuthenticated(); // Permite buscar reinos por código de convite e ver detalhes ao ser convidado
      allow create: if isAuthenticated();
      allow update: if isAdmin(kingdomId) || isSuperAdmin();
      allow delete: if (isAuthenticated() && resource.data.owner_id == request.auth.uid) || isSuperAdmin();
    }

    // Kingdom Members
    match /kingdom_members/{memberId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid || 
        isKingdomMember(resource.data.kingdom_id) ||
        isSuperAdmin()
      );
      allow create: if isAuthenticated(); // O próprio sistema cria ao criar reino ou aceitar convite
      allow update: if isAdmin(resource.data.kingdom_id) || isSuperAdmin();
      allow delete: if isSuperAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/kingdoms/$(resource.data.kingdom_id)).data.owner_id == request.auth.uid);
    }

    // Kingdom Invites
    match /kingdom_invites/{inviteId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.email || 
        isAdmin(resource.data.kingdom_id) ||
        isSuperAdmin()
      );
      allow create: if isAdmin(request.resource.data.kingdom_id) || isSuperAdmin();
      allow update: if isAuthenticated() && (
        request.auth.token.email == resource.data.email || 
        isAdmin(resource.data.kingdom_id) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/kingdoms/$(resource.data.kingdom_id)).data.owner_id == request.auth.uid);
    }

    // Transactions
    match /transactions/{transactionId} {
      function isValidTransaction() {
        return hasRequiredFields(['amount', 'description', 'category_id', 'kingdom_id', 'type', 'date']) &&
               request.resource.data.amount is number &&
               isValidString('description', 1, 200) &&
               request.resource.data.type in ['income', 'expense', 'investment'];
      }

      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id) && 
                      hasRequiredFields(['amount', 'description', 'category_id', 'kingdom_id', 'type', 'date']) &&
                      request.resource.data.amount is number &&
                      isValidString('description', 1, 200) &&
                      request.resource.data.type in ['income', 'expense', 'investment'];
      allow update: if isMember(resource.data.kingdom_id) && 
                      (request.resource.data.kingdom_id == null || isMember(request.resource.data.kingdom_id)) && 
                      hasRequiredFields(['amount', 'description', 'category_id', 'kingdom_id', 'type', 'date']) &&
                      request.resource.data.amount is number &&
                      isValidString('description', 1, 200) &&
                      request.resource.data.type in ['income', 'expense', 'investment'];
      allow delete: if canDelete(resource.data);
    }

    // Accounts Payable
    match /accounts_payable/{payableId} {
      function isValidPayable() {
        return hasRequiredFields(['amount', 'description', 'category_id', 'kingdom_id', 'status']) &&
               (hasRequiredFields(['dueDate']) || hasRequiredFields(['due_date'])) &&
               isValidNumber('amount', 0) &&
               request.resource.data.status in ['pendente', 'pago', 'atrasado', 'pending', 'paid', 'overdue'];
      }

      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id) && isValidPayable();
      allow update: if isMember(resource.data.kingdom_id) && isMember(request.resource.data.kingdom_id) && isValidPayable();
      allow delete: if canDelete(resource.data);
    }

    // Accounts Receivable
    match /accounts_receivable/{receivableId} {
      function isValidReceivable() {
        return hasRequiredFields(['amount', 'description', 'category_id', 'kingdom_id', 'status']) &&
               (hasRequiredFields(['dueDate']) || hasRequiredFields(['due_date'])) &&
               isValidNumber('amount', 0) &&
               request.resource.data.status in ['pendente', 'recebido', 'atrasado', 'inadimplente', 'pending', 'received', 'overdue', 'defaulted'];
      }

      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id) && isValidReceivable();
      allow update: if isMember(resource.data.kingdom_id) && isMember(request.resource.data.kingdom_id) && isValidReceivable();
      allow delete: if canDelete(resource.data);
    }

    // Budgets
    match /budgets/{budgetId} {
      allow read: if 'kingdom_id' in resource.data && isViewer(resource.data.kingdom_id);
      allow create: if 'kingdom_id' in request.resource.data && isMember(request.resource.data.kingdom_id);
      allow update: if ('kingdom_id' in resource.data && isMember(resource.data.kingdom_id)) && ('kingdom_id' in request.resource.data && isMember(request.resource.data.kingdom_id));
      allow delete: if ('kingdom_id' in resource.data && isMember(resource.data.kingdom_id)) || canDelete(resource.data);
    }

    // Credit Cards
    match /credit_cards/{cardId} {
      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id);
      allow update: if isMember(resource.data.kingdom_id) && isMember(request.resource.data.kingdom_id);
      allow delete: if canDelete(resource.data);
    }

    // Credit Card Invoices
    match /credit_card_invoices/{invoiceId} {
      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id);
      allow update: if isMember(resource.data.kingdom_id) && isMember(request.resource.data.kingdom_id);
      allow delete: if canDelete(resource.data);
    }

    // Investments
    match /investments/{investmentId} {
      allow read: if isAuthenticated();
      allow create: if isMember(request.resource.data.kingdom_id);
      allow update: if isMember(resource.data.kingdom_id) && 
                      (request.resource.data.kingdom_id == null || isMember(request.resource.data.kingdom_id));
      allow delete: if canDelete(resource.data);
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if 'kingdom_id' in resource.data && isViewer(resource.data.kingdom_id);
      allow create: if isAuthenticated() && 'kingdom_id' in request.resource.data && isKingdomMember(request.resource.data.kingdom_id);
      allow update: if false;
      allow delete: if ('kingdom_id' in resource.data && isMember(resource.data.kingdom_id)) || canDelete(resource.data);
    }

    // Contribution Planning
    match /contribution_planning/{planningId} {
      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id);
      allow update: if isMember(resource.data.kingdom_id) && 
                      (request.resource.data.kingdom_id == null || isMember(request.resource.data.kingdom_id));
      allow delete: if canDelete(resource.data);
    }

    // Categories (Custom per Kingdom)
    match /categories/{categoryId} {
      allow read: if isViewer(resource.data.kingdom_id);
      allow create: if isMember(request.resource.data.kingdom_id);
      allow update: if isMember(resource.data.kingdom_id) && isMember(request.resource.data.kingdom_id);
      allow delete: if canDelete(resource.data);
    }

    // Market Data (Global, read-only for users)
    match /market_data/{ticker} {
      allow read, write: if true;
    }

    // Market Config (Admin SDK only)
    match /market_config/{docId} {
      allow read, write: if true;
    }

    // Market Usage Logs (Admin SDK only)
    match /market_usage_logs/{logId} {
      allow read, write: if true;
    }
  }
}
