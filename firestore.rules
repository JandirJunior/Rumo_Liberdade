rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (SaaS)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserOrgId() {
      return getUserData().organizationId;
    }
    
    function getUserRole() {
      return getUserData().role;
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && getUserOrgId() == orgId;
    }
    
    function hasRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }
    
    function isSuperAdmin() {
      return hasRole(['superadmin']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /organizations/{orgId} {
      // Qualquer usuário da organização pode ler os dados dela, ou superadmin
      allow read: if isOrgMember(orgId) || isSuperAdmin();
      // Apenas superadmin pode criar novas organizações via painel (ou via cloud function no onboarding)
      // Como o onboarding é feito no client-side para o primeiro usuário, permitimos a criação se o usuário estiver autenticado e o orgId for baseado no uid dele
      allow create: if isAuthenticated() && (isSuperAdmin() || orgId == 'org_' + request.auth.uid);
      // Apenas admin da organização ou superadmin pode atualizar
      allow update: if (isOrgMember(orgId) && hasRole(['admin'])) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /subscriptions/{subId} {
      allow read: if (isAuthenticated() && resource != null && isOrgMember(resource.data.organizationId)) || isSuperAdmin();
      allow write: if isSuperAdmin(); // Apenas o sistema/superadmin gerencia assinaturas
    }

    match /logs/{logId} {
      allow read: if (isAuthenticated() && resource != null && isOrgMember(resource.data.organizationId) && hasRole(['admin'])) || isSuperAdmin();
      allow create: if isAuthenticated() && isOrgMember(request.resource.data.organizationId);
      allow update, delete: if false; // Logs são imutáveis
    }

    match /settings/{settingId} {
      allow read: if (isAuthenticated() && resource != null && isOrgMember(resource.data.organizationId)) || isSuperAdmin();
      allow write: if (isAuthenticated() && isOrgMember(request.resource.data.organizationId) && hasRole(['admin'])) || isSuperAdmin();
    }

    // ===============================================================
    // Coleções do Aplicativo F.A.C.E.R.O. (Isoladas por Tenant)
    // ===============================================================

    match /reino_transactions/{transactionId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.organizationId);
      allow create: if isAuthenticated() && isOrgMember(request.resource.data.organizationId) && hasRole(['admin', 'manager', 'user']);
      allow update: if isAuthenticated() && isOrgMember(resource.data.organizationId) && isOrgMember(request.resource.data.organizationId) && hasRole(['admin', 'manager', 'user']);
      allow delete: if isAuthenticated() && isOrgMember(resource.data.organizationId) && hasRole(['admin', 'manager', 'user']);
    }

    match /reino_assets/{assetId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.organizationId);
      allow create: if isAuthenticated() && isOrgMember(request.resource.data.organizationId) && hasRole(['admin', 'manager', 'user']);
      allow update: if isAuthenticated() && isOrgMember(resource.data.organizationId) && isOrgMember(request.resource.data.organizationId) && hasRole(['admin', 'manager', 'user']);
      allow delete: if isAuthenticated() && isOrgMember(resource.data.organizationId) && hasRole(['admin', 'manager', 'user']);
    }

    // ===============================================================
    // Coleções do Motor Financeiro (Financial Engine)
    // ===============================================================

    match /categories/{categoryId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /accounts/{accountId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /investments/{investmentId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /accounts_payable/{payableId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /accounts_receivable/{receivableId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /credit_cards/{cardId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /credit_card_invoices/{invoiceId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
