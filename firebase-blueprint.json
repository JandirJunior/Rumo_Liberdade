{
  "entities": {
    "Kingdom": {
      "title": "Kingdom",
      "description": "Represents a kingdom (tenant) in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "owner_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "owner_id", "created_at"]
    },
    "KingdomMember": {
      "title": "KingdomMember",
      "description": "Represents a member of a kingdom.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "kingdom_id": { "type": "string" },
        "user_id": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "membro", "visualizador"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "kingdom_id", "user_id", "role", "created_at"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "archetype": {
          "type": "string",
          "description": "The chosen archetype/class of the user."
        },
        "xp": {
          "type": "number",
          "description": "The user's total experience points."
        },
        "stats": {
          "type": "object",
          "description": "The user's F.A.C.E.R.O. stats.",
          "properties": {
            "F": { "type": "number" },
            "A": { "type": "number" },
            "C": { "type": "number" },
            "E": { "type": "number" },
            "R": { "type": "number" },
            "O": { "type": "number" }
          }
        },
        "theme": {
          "type": "string",
          "description": "The user's chosen theme."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the user was created."
        }
      },
      "required": ["uid", "email", "archetype", "xp", "stats", "theme", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a financial transaction.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the transaction."
        },
        "user_id": {
          "type": "string",
          "description": "The ID of the user who owns the transaction."
        },
        "description": {
          "type": "string",
          "description": "The title or description of the transaction."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the transaction."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the transaction."
        },
        "category_id": {
          "type": "string",
          "description": "The ID of the category."
        },
        "investment_category_id": {
          "type": "string",
          "description": "The ID of the investment category, if applicable."
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense", "investment", "transfer"],
          "description": "The type of the transaction."
        },
        "status": {
          "type": "string",
          "enum": ["concluído", "pendente"],
          "description": "The status of the transaction."
        },
        "source": {
          "type": "string",
          "enum": ["manual", "importação", "investimento"],
          "description": "The source of the transaction."
        },
        "kingdom_id": {
          "type": "string",
          "description": "The ID of the kingdom."
        },
        "created_by": {
          "type": "string",
          "description": "The ID of the user who created the transaction."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the transaction was created."
        }
      },
      "required": ["id", "user_id", "description", "amount", "date", "type", "category_id", "kingdom_id", "created_by", "created_at"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Represents an achievement unlocked by the user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the achievement."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who unlocked the achievement."
        },
        "unlockedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the achievement was unlocked."
        }
      },
      "required": ["id", "userId", "unlockedAt"]
    },
    "Account": {
      "title": "Account",
      "description": "Represents a financial account.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["checking", "credit_card", "wallet", "digital_account"] },
        "current_balance": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "name", "type", "current_balance", "created_at"]
    },
    "Category": {
      "title": "Category",
      "description": "Represents a financial category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "group_type": { "type": "string", "enum": ["fixed", "variable"] },
        "flow_type": { "type": "string", "enum": ["income", "expense"] },
        "rpg_group": { "type": "string" },
        "allowed_profiles": {
          "type": "array",
          "items": { "type": "string", "enum": ["MonoUsuario", "MultiUsuario"] }
        },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "rpg_theme_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "name", "group_type", "flow_type", "rpg_group", "allowed_profiles", "icon", "color", "rpg_theme_name", "created_at"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Represents a budget for a category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "category_id": { "type": "string" },
        "budget_amount": { "type": "number" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "kingdom_id": { "type": "string" },
        "created_by": { "type": "string" }
      },
      "required": ["id", "user_id", "category_id", "budget_amount", "month", "year", "kingdom_id", "created_by"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Represents an investment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["stock", "fii", "crypto", "etf", "fixed_income"] },
        "ticker": { "type": "string" },
        "quantity": { "type": "number" },
        "average_price": { "type": "number" },
        "invested_value": { "type": "number" },
        "current_value": { "type": "number" },
        "earnings": { "type": "number" }
      },
      "required": ["id", "user_id", "type", "ticker", "quantity", "average_price", "invested_value", "current_value", "earnings"]
    },
    "AccountPayable": {
      "title": "AccountPayable",
      "description": "Represents an account payable (bill).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category_id": { "type": "string" },
        "due_date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "paid", "overdue", "cancelled"] },
        "payment_method": { "type": "string" },
        "credit_card_id": { "type": "string" },
        "installments": { "type": "number" },
        "current_installment": { "type": "number" },
        "is_recurring": { "type": "boolean" },
        "recurrence_rule": { "type": "string" },
        "next_recurrence_date": { "type": "string", "format": "date" },
        "kingdom_id": { "type": "string" },
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "paid_at": { "type": "string", "format": "date-time" },
        "transaction_id": { "type": "string" }
      },
      "required": ["id", "user_id", "description", "amount", "category_id", "due_date", "status", "kingdom_id", "created_by", "created_at"]
    },
    "AccountReceivable": {
      "title": "AccountReceivable",
      "description": "Represents an account receivable.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category_id": { "type": "string" },
        "due_date": { "type": "string", "format": "date" },
        "payer": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "received", "defaulted", "cancelled"] },
        "is_recurring": { "type": "boolean" },
        "recurrence_rule": { "type": "string" },
        "next_recurrence_date": { "type": "string", "format": "date" },
        "kingdom_id": { "type": "string" },
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "received_at": { "type": "string", "format": "date-time" },
        "transaction_id": { "type": "string" }
      },
      "required": ["id", "user_id", "description", "amount", "category_id", "due_date", "status", "kingdom_id", "created_by", "created_at"]
    },
    "CreditCard": {
      "title": "CreditCard",
      "description": "Represents a credit card.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "limit": { "type": "number" },
        "closingDay": { "type": "number" },
        "dueDay": { "type": "number" }
      },
      "required": ["id", "userId", "name", "limit", "closingDay", "dueDay"]
    },
    "CreditCardInvoice": {
      "title": "CreditCardInvoice",
      "description": "Represents a credit card invoice.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cardId": { "type": "string" },
        "userId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "closingDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed", "paid", "overdue"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" },
        "transactionId": { "type": "string" }
      },
      "required": ["id", "cardId", "userId", "month", "year", "closingDate", "dueDate", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "kingdoms/{kingdomId}": {
      "schema": { "$ref": "#/entities/Kingdom" },
      "description": "Stores kingdoms."
    },
    "kingdom_members/{memberId}": {
      "schema": { "$ref": "#/entities/KingdomMember" },
      "description": "Stores kingdom members."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "accounts/{accountId}": {
      "schema": { "$ref": "#/entities/Account" },
      "description": "Stores user accounts."
    },
    "transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores transactions."
    },
    "categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Stores categories."
    },
    "budgets/{budgetId}": {
      "schema": { "$ref": "#/entities/Budget" },
      "description": "Stores budgets."
    },
    "investments/{investmentId}": {
      "schema": { "$ref": "#/entities/Investment" },
      "description": "Stores investments."
    },
    "accounts_payable/{payableId}": {
      "schema": { "$ref": "#/entities/AccountPayable" },
      "description": "Stores accounts payable (bills)."
    },
    "accounts_receivable/{receivableId}": {
      "schema": { "$ref": "#/entities/AccountReceivable" },
      "description": "Stores accounts receivable."
    },
    "credit_cards/{cardId}": {
      "schema": { "$ref": "#/entities/CreditCard" },
      "description": "Stores credit cards."
    },
    "credit_card_invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/CreditCardInvoice" },
      "description": "Stores credit card invoices."
    }
  }
}
